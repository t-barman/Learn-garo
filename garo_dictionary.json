  "classifier_engine": {
    "_description": "Garo uses noun classifiers (like counters) that must be attached when referring to quantities of a noun. Use the correct classifier based on the noun category.",
    "Mang": {
      "use_for": ["animals", "birds", "fish", "insects"],
      "examples": [
        { "english": "one dog", "garo": "achak sa·mang" },
        { "english": "two birds", "garo": "do·o gni·mang" },
        { "english": "three fish", "garo": "na·tok gittam·mang" }
      ]
    },
    "Sak": {
      "use_for": ["people", "persons", "humans"],
      "examples": [
        { "english": "one person", "garo": "manderang sa·sak" },
        { "english": "two teachers", "garo": "skigipa gni·sak" },
        { "english": "three children", "garo": "bi·sa gittam·sak" }
      ]
    },
    "Gong": {
      "use_for": ["money", "coins", "currency"],
      "examples": [
        { "english": "one coin", "garo": "tangka sa·gong" },
        { "english": "five rupees", "garo": "tangka bonga·gong" }
      ]
    },
    "King": {
      "use_for": ["books", "paper", "leaves", "flat thin objects"],
      "examples": [
        { "english": "one book", "garo": "ki·tap sa·king" },
        { "english": "two papers", "garo": "lekka gni·king" },
        { "english": "three leaves", "garo": "bijak gittam·king" }
      ]
    },
    "Ge": {
      "use_for": ["objects", "things", "items", "tools", "general nouns"],
      "examples": [
        { "english": "one chair", "garo": "chokki sa·ge" },
        { "english": "two knives", "garo": "kettal gni·ge" },
        { "english": "three pots", "garo": "dik·ke gittam·ge" }
      ]
    }
  },

